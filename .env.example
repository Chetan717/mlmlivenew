# Razorpay public key for the subscription checkout flow.
# Get this from your Razorpay dashboard (Settings > API Keys).
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# 2Factor.in SMS API key for OTP delivery during signup.
# Get this from your 2factor.in dashboard.
VITE_TWOFACTOR_API_KEY=your_2factor_api_key_here
