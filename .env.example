# Firebase configuration (VITE_ prefix = visible in browser bundle — use Firestore Security Rules to restrict access)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Razorpay public key (safe to expose in browser)
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# Payment server API key — must match VALID_API_KEYS in pserver .env
# Generate: openssl rand -hex 32
VITE_PSERVER_API_KEY=your_strong_pserver_api_key_here

# Payment server base URL
VITE_PSERVER_URL=https://your-pserver.example.com

# 2Factor SMS API key
VITE_TWOFACTOR_API_KEY=your_2factor_api_key_here

# Firestore Collection Names
VITE_COL_USERS=users
VITE_COL_ADMINUSER=adminuser
VITE_COL_COUPONCODE=couponcode
VITE_COL_MTEAM=mteam
VITE_COL_SUBSCRIPTION=subscription
VITE_COL_MLMCOMP=mlmcomp
VITE_COL_MLMPROFILES=mlmprofiles
VITE_COL_MLMTEMPLATE=mlmtemplate
VITE_COL_LEADMANAGEMENT=leadmanagement
VITE_COL_MLMGRAPHICS=mlmgraphics
VITE_COL_REMOVEBG=removebg
VITE_COL_PAYMENTLOG=paymentlog
VITE_COL_REPORTINGUSER=reportingUser
VITE_COL_REPORTPLAN=reportplan
VITE_COL_REPORTSP=reportsp
VITE_COL_REPORTFOLLOWUP=reportfollowup
VITE_COL_REPORTKITBOOK=reportkitbook
VITE_COL_REPORTNAC=reportnac
VITE_COL_REPORTNEXTDAY=reportnextday
